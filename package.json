{
  "name": "unstpbl",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,green \"pnpm --filter @unstpbl/web dev\" \"pnpm --filter @unstpbl/api dev\"",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter @unstpbl/db migrate",
    "db:seed": "pnpm --filter @unstpbl/db seed",
    "db:seed:full": "pnpm --filter @unstpbl/db seed:full",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "typescript": "~5.5.0"
  }
}
